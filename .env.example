# ─── DATABASE ───────────────────────────────────────────────
DATABASE_URL=postgresql://omniwallet:password@localhost:5432/omniwallet
REDIS_URL=redis://localhost:6379

# ─── AUTH ────────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_SECRET=your-refresh-token-secret

# ─── ENCRYPTION ──────────────────────────────────────────────
ENCRYPTION_KEY=32-byte-hex-key-for-aes256-encryption

# ─── BLOCKCHAIN RPC ──────────────────────────────────────────
ETHEREUM_RPC_URL=https://mainnet.infura.io/v3/YOUR_INFURA_KEY
ETHEREUM_SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_KEY
POLYGON_RPC_URL=https://polygon-mainnet.infura.io/v3/YOUR_INFURA_KEY
BSC_RPC_URL=https://bsc-dataseed.binance.org
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
BITCOIN_RPC_URL=https://blockstream.info/api

# ─── PRICE FEEDS ─────────────────────────────────────────────
COINGECKO_API_KEY=your-coingecko-api-key
COINGECKO_BASE_URL=https://api.coingecko.com/api/v3

# ─── WALLETCONNECT ───────────────────────────────────────────
WALLETCONNECT_PROJECT_ID=your-walletconnect-project-id

# ─── EMAIL (SMTP) ─────────────────────────────────────────────
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your-sendgrid-api-key
EMAIL_FROM=noreply@omniwallet.app

# ─── APP ─────────────────────────────────────────────────────
NODE_ENV=development
API_PORT=4000
FRONTEND_URL=http://localhost:3000
API_URL=http://localhost:4000

# ─── RATE LIMITING ───────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
